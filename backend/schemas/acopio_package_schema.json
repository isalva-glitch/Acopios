{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://fontelacristales.com/schemas/acopio-package.json",
    "title": "Acopio Package",
    "description": "JSON Schema para validar el package de extracción de PDFs de acopios",
    "type": "object",
    "required": [
        "meta",
        "acopio"
    ],
    "properties": {
        "meta": {
            "type": "object",
            "required": [
                "extraction_date",
                "pdf_filename",
                "pdf_hash"
            ],
            "properties": {
                "extraction_date": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Fecha y hora de la extracción"
                },
                "pdf_filename": {
                    "type": "string",
                    "description": "Nombre del archivo PDF procesado"
                },
                "pdf_hash": {
                    "type": "string",
                    "pattern": "^[a-f0-9]{64}$",
                    "description": "Hash SHA256 del archivo PDF"
                },
                "extractor_version": {
                    "type": "string",
                    "description": "Versión del extractor utilizado"
                }
            }
        },
        "acopio": {
            "type": "object",
            "required": [
                "obra",
                "cliente"
            ],
            "properties": {
                "numero": {
                    "type": "string"
                },
                "fecha_alta": {
                    "type": "string",
                    "format": "date"
                },
                "obra": {
                    "type": "string",
                    "description": "Nombre de la obra"
                },
                "cliente": {
                    "type": "string",
                    "description": "Nombre del cliente"
                },
                "total_m2": {
                    "type": "number",
                    "minimum": 0
                },
                "total_ml": {
                    "type": "number",
                    "minimum": 0
                },
                "total_pesos": {
                    "type": "number",
                    "minimum": 0
                }
            }
        },
        "presupuestos": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "numero",
                    "fecha"
                ],
                "properties": {
                    "numero": {
                        "type": "string"
                    },
                    "fecha": {
                        "type": "string",
                        "format": "date"
                    },
                    "condiciones": {
                        "type": "string"
                    },
                    "estado": {
                        "type": "string"
                    }
                }
            }
        },
        "items": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "descripcion"
                ],
                "properties": {
                    "descripcion": {
                        "type": "string"
                    },
                    "material": {
                        "type": "string"
                    },
                    "tipologia": {
                        "type": "string"
                    },
                    "cantidad": {
                        "type": "integer",
                        "minimum": 0
                    },
                    "total_m2": {
                        "type": "number",
                        "minimum": 0
                    },
                    "total_ml": {
                        "type": "number",
                        "minimum": 0
                    },
                    "total_pesos": {
                        "type": "number",
                        "minimum": 0
                    }
                }
            }
        },
        "panos": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "item_index",
                    "cantidad",
                    "ancho",
                    "alto"
                ],
                "properties": {
                    "item_index": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Índice del item al que pertenece este paño"
                    },
                    "cantidad": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "ancho": {
                        "type": "number",
                        "minimum": 0
                    },
                    "alto": {
                        "type": "number",
                        "minimum": 0
                    },
                    "superficie_m2": {
                        "type": "number",
                        "minimum": 0
                    },
                    "perimetro_ml": {
                        "type": "number",
                        "minimum": 0
                    },
                    "precio_unitario": {
                        "type": "number",
                        "minimum": 0
                    },
                    "precio_total": {
                        "type": "number",
                        "minimum": 0
                    }
                }
            }
        },
        "pedidos": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "numero",
                    "fecha"
                ],
                "properties": {
                    "numero": {
                        "type": "string"
                    },
                    "fecha": {
                        "type": "string",
                        "format": "date"
                    },
                    "total_m2": {
                        "type": "number",
                        "minimum": 0
                    },
                    "total_ml": {
                        "type": "number",
                        "minimum": 0
                    },
                    "total_pesos": {
                        "type": "number",
                        "minimum": 0
                    }
                }
            }
        },
        "remitos": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "numero",
                    "fecha",
                    "pedido_numero"
                ],
                "properties": {
                    "numero": {
                        "type": "string"
                    },
                    "fecha": {
                        "type": "string",
                        "format": "date"
                    },
                    "pedido_numero": {
                        "type": "string",
                        "description": "Número del pedido al que pertenece"
                    },
                    "descripcion": {
                        "type": "string"
                    }
                }
            }
        },
        "imputaciones": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "pedido_numero",
                    "cantidad_m2",
                    "cantidad_ml",
                    "cantidad_pesos"
                ],
                "properties": {
                    "pedido_numero": {
                        "type": "string"
                    },
                    "cantidad_m2": {
                        "type": "number",
                        "minimum": 0
                    },
                    "cantidad_ml": {
                        "type": "number",
                        "minimum": 0
                    },
                    "cantidad_pesos": {
                        "type": "number",
                        "minimum": 0
                    },
                    "es_excedente": {
                        "type": "boolean"
                    }
                }
            }
        },
        "comprobantes": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "tipo",
                    "numero",
                    "fecha",
                    "importe"
                ],
                "properties": {
                    "tipo": {
                        "type": "string",
                        "enum": [
                            "FAC_ANTICIPO",
                            "RECIBO",
                            "FAC_MERCADERIA",
                            "NC"
                        ]
                    },
                    "numero": {
                        "type": "string"
                    },
                    "fecha": {
                        "type": "string",
                        "format": "date"
                    },
                    "importe": {
                        "type": "number"
                    },
                    "descripcion": {
                        "type": "string"
                    }
                }
            }
        },
        "afectaciones_acopio": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "comprobante_numero",
                    "importe"
                ],
                "properties": {
                    "comprobante_numero": {
                        "type": "string"
                    },
                    "importe": {
                        "type": "number"
                    }
                }
            }
        },
        "documentos": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "tipo_documento",
                    "nombre_archivo",
                    "hash"
                ],
                "properties": {
                    "tipo_documento": {
                        "type": "string"
                    },
                    "nombre_archivo": {
                        "type": "string"
                    },
                    "hash": {
                        "type": "string",
                        "pattern": "^[a-f0-9]{64}$"
                    }
                }
            }
        },
        "warnings": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "level",
                    "message"
                ],
                "properties": {
                    "level": {
                        "type": "string",
                        "enum": [
                            "INFO",
                            "WARNING",
                            "ERROR"
                        ]
                    },
                    "message": {
                        "type": "string"
                    },
                    "field": {
                        "type": "string"
                    },
                    "expected": {},
                    "actual": {},
                    "tolerance": {
                        "type": "number"
                    }
                }
            }
        }
    }
}